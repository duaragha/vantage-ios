{
  "name": "@vantage/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/lib/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify:audit-soak": "node dist/scripts/verifyAuditSoak.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.91.1",
    "@vantage/core": "workspace:*",
    "@vantage/db": "workspace:*",
    "@vantage/llm": "workspace:*",
    "@vantage/notify": "workspace:*",
    "@vantage/sources": "workspace:*",
    "croner": "10.0.1",
    "fastify": "^5.3.2",
    "p-queue": "^9.1.2",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  }
}
