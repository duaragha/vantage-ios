# Data sources
FINNHUB_API_KEY=your_finnhub_api_key
TIINGO_API_KEY=your_tiingo_api_key
FRED_API_KEY=your_fred_api_key
ALPACA_KEY_ID=your_alpaca_key_id
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Twelve Data is used only for its public Canadian /stocks universe endpoint.
# Live quotes use Alpaca, Finnhub, yfinance, and provider-agnostic stored closes.

# StockTwits retired anonymous v2 API access and is not accepting new developer
# registrations. Leave disabled unless this installation has approved API
# access; a 401/403 circuit-breaks the source until the worker restarts.
STOCKTWITS_ENABLED=false

# LLM
ANTHROPIC_API_KEY=sk-ant-your-key-here
TAVILY_API_KEY=

# Vantage app notifications. Generate one VAPID pair with `web-push` and keep
# the private key on the worker only. The web service needs the public key.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=https://vantagee.up.railway.app

# Legacy Telegram channel. Leave unset when app notifications are the only
# phone-delivery path.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SEC EDGAR requires a descriptive UA with contact email
EDGAR_USER_AGENT=vantage you@example.com

# DB (host-side; docker compose overrides DATABASE_URL inside containers).
# 5435 is the host port the vantage-postgres container publishes.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=vantage
DATABASE_URL=postgresql://postgres:change_me_strong_password@localhost:5435/vantage

# Timezone
TZ=America/Toronto

# Session / auth (Phase 12)
ADMIN_PASSWORD_HASH=
# Base64 form is safer in Docker env files because bcrypt hashes contain '$'.
# The DB hash changed in Settings is authoritative. These env hashes are the
# seed/recovery fallback; when both env forms are set, the B64 form wins.
ADMIN_PASSWORD_HASH_B64=
SESSION_SECRET=change_me_32_plus_chars_random_string
# Seed-only plaintext. Do not keep this set after generating the hash.
ADMIN_PASSWORD=

# Worker <-> web shared secret
WORKER_SECRET=change_me_random_string

# Shared local-embedding service. Railway should use the private service URL.
# EMBEDDER_SECRET may be omitted to reuse WORKER_SECRET.
EMBEDDER_URL=http://localhost:3002
EMBEDDER_SECRET=
EMBEDDER_HOST=0.0.0.0
EMBEDDER_PORT=3002
# Railway's HTTP service leaves sweeps disabled and uses an hourly cron
# service. Docker Compose overrides this to one hour for gaming-PC parity.
EMBED_SWEEP_INTERVAL_MS=0
EMBED_MAX_ROWS=1000
EMBED_QUERY_BATCH_SIZE=128

# Worker port
WORKER_HOST=0.0.0.0
WORKER_PORT=3001

# Worker URL (used by the web app to proxy the backtest endpoint).
WORKER_URL=http://localhost:3001

# Dashboard base URL used for secure-cookie policy and Telegram deep links.
# In dev this is Next.js; in production use the PC's HTTPS Tailscale URL.
DASHBOARD_BASE_URL=http://localhost:3000

# Structured logging
LOG_LEVEL=info
SERVICE_NAME=
# Optional diagnostics for the legacy PM2 env preloader.
VANTAGE_DEBUG_ENV=0

# Optional SideStore/mobile release proxy
TAILSCALE_BASE_URL=
CODEMAGIC_API_TOKEN=
CAPACITOR_SERVER_URL=

# Phase 16 — FX fallback rate (CAD per USD) used when FRED DEXCAUS is
# unreachable. Defaults to 1.36 (roughly the long-term USD/CAD average as of
# 2026). Only relevant in degraded-network scenarios; normal operation pulls
# the live FRED value and caches for 1h.
# FX_USD_CAD_FALLBACK=1.36

# Hard daily ceiling on alert-purpose LLM calls (deterministic gate in the
# alert dispatcher). Steady state is ~12/day; the cap exists to bound backlog
# drains after outages/restarts. Events over the cap defer to the next ET day.
# ALERT_DAILY_LLM_CAP=40
