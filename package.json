{
  "name": "vantage",
  "version": "0.0.0",
  "private": true,
  "description": "Personal equity research and portfolio optimization agent",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter './packages/**' -r build",
    "test": "pnpm -r --if-present test",
    "test:railway-cost": "node --test scripts/estimate-railway-cost.test.mjs",
    "cost:railway": "node scripts/estimate-railway-cost.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm build:packages && pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.17",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
