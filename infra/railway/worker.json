{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/worker/Dockerfile",
    "watchPatterns": [
      "/infra/railway/worker.json",
      "/apps/worker/**",
      "/packages/core/**",
      "/packages/db/**",
      "/packages/llm/**",
      "/packages/notify/**",
      "/packages/sources/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 180,
    "sleepApplication": false,
    "runtime": "V2",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 20,
    "drainingSeconds": 20,
    "limitOverride": {
      "containers": {
        "cpu": 1,
        "memoryBytes": 536870912
      }
    }
  }
}
