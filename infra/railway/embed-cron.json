{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/embedder/Dockerfile",
    "watchPatterns": [
      "/infra/railway/embed-cron.json",
      "/apps/embedder/**",
      "/packages/db/**",
      "/packages/embed/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml"
    ]
  },
  "deploy": {
    "startCommand": "node dist/batch.js",
    "cronSchedule": "0 * * * *",
    "sleepApplication": false,
    "runtime": "V2",
    "restartPolicyType": "NEVER",
    "limitOverride": {
      "containers": {
        "cpu": 1,
        "memoryBytes": 1610612736
      }
    }
  }
}
