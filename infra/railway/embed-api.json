{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/embedder/Dockerfile",
    "watchPatterns": [
      "/infra/railway/embed-api.json",
      "/apps/embedder/**",
      "/packages/db/**",
      "/packages/embed/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml"
    ]
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "sleepApplication": true,
    "runtime": "V2",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "limitOverride": {
      "containers": {
        "cpu": 1,
        "memoryBytes": 1610612736
      }
    }
  }
}
